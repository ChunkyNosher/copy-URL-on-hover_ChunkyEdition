{
  "name": "copy-url-on-hover-chunkyedition",
  "version": "1.6.3",
  "description": "Copy URL on Hover extension with hybrid modular architecture, solo/mute Quick Tabs, and persistent panel manager",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build": "npm run clean && npm run build:vite",
    "build:dev": "npm run build:vite",
    "build:vite": "npm run build:vite:content && npm run build:vite:background",
    "build:vite:content": "EMPTY_OUT_DIR=true COPY_STATIC=true BUILD_TARGET=content vp build",
    "build:vite:background": "EMPTY_OUT_DIR=false COPY_STATIC=false BUILD_TARGET=background vp build",
    "build:test": "npm run clean && TEST_MODE=true npm run build:vite && TEST_MODE=true node scripts/inject-test-bridge.cjs",
    "build:prod": "npm run clean && BUILD=production npm run build:vite",
    "build:analyze": "BUILD=production npm run build:vite",
    "build:check-size": "node scripts/check-bundle-size.js",
    "watch": "npm-run-all --parallel watch:content watch:background",
    "watch:content": "EMPTY_OUT_DIR=true COPY_STATIC=true BUILD_TARGET=content vp build --watch",
    "watch:background": "EMPTY_OUT_DIR=false COPY_STATIC=false BUILD_TARGET=background vp build --watch",
    "clean": "rm -rf dist && mkdir -p dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:domain": "jest --testPathPattern=tests/unit/domain --coverage --coverageThreshold='{\"global\":{\"branches\":100,\"functions\":100,\"lines\":100,\"statements\":100}}'",
    "test:storage": "jest --testPathPattern=tests/unit/storage --coverage",
    "test:watch:unit": "jest --testPathPattern=tests/unit --watch",
    "test:watch:integration": "jest --testPathPattern=tests/integration --watch",
    "coverage:domain": "jest --testPathPattern=tests/unit/domain --coverage --collectCoverageFrom='src/domain/**/*.js'",
    "coverage:storage": "jest --testPathPattern=tests/unit/storage --coverage --collectCoverageFrom='src/storage/**/*.js'",
    "coverage:features": "jest --testPathPattern=tests/unit --coverage --collectCoverageFrom='src/features/**/*.js'",
    "validate:architecture": "node scripts/validate-architecture.js",
    "validate:imports": "eslint src/ --rule 'import/no-restricted-paths: error'",
    "validate:manifest": "node scripts/validate-manifest.js",
    "validate:test-bridge": "node scripts/verify-test-bridge.cjs",
    "ci:lint": "npm-run-all --parallel lint format:check",
    "ci:test": "npm-run-all --sequential test:unit test:integration",
    "ci:build": "npm run build:prod && npm run build:check-size",
    "ci:full": "npm run ci:lint && npm run ci:test && npm run ci:build",
    "test:extension": "playwright test --config=playwright.config.firefox.js",
    "test:extension:chrome": "playwright test --config=playwright.config.chrome.js --project=chromium-extension",
    "test:extension:firefox": "playwright test --config=playwright.config.firefox.js --project=firefox-extension",
    "test:extension:debug": "playwright test --config=playwright.config.firefox.js --debug",
    "test:extension:ui": "playwright test --config=playwright.config.firefox.js --ui",
    "test:extension:report": "playwright show-report",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test && npm run test:e2e",
    "mcp:chrome": "node scripts/load-extension-chrome.js",
    "mcp:firefox": "node scripts/load-extension-firefox.js",
    "dev:firefox": "web-ext run --source-dir=dist --firefox=firefox --keep-profile-changes",
    "dev:chrome": "web-ext run --source-dir=dist --target=chromium",
    "dev:both": "web-ext run --source-dir=dist --target=firefox-desktop --target=chromium",
    "package": "web-ext build --overwrite-dest",
    "package:source": "web-ext build --as-tmp-file --source-dir=.",
    "package:firefox": "npm run build:prod && node scripts/package-firefox.cjs",
    "package:chrome": "npm run build:prod && node scripts/package-chrome.cjs",
    "lint:webext": "web-ext lint",
    "sign:firefox": "web-ext sign --channel=unlisted",
    "lint:specific": "eslint",
    "lint:print-config": "eslint --print-config",
    "lint:cache": "eslint --cache --cache-location node_modules/.cache/eslint",
    "lint:fix:dry": "eslint --fix-dry-run",
    "lint:output-file": "eslint --output-file eslint-report.json --format json",
    "debug:background": "node --inspect-brk background.js",
    "debug:popup": "node --inspect-brk popup.js",
    "profile:build": "npm run build -- --profile",
    "analyze:bundle": "BUILD=production npm run build:vite",
    "check:types": "tsc --noEmit"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@playwright/test": "^1.57.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.1",
    "@types/webextension-polyfill": "^0.12.4",
    "@voidzero-dev/vite-plus-core": "^0.1.13",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^27.2.0",
    "npm-run-all": "^4.1.5",
    "playwright-webextext": "^0.0.4",
    "prettier": "^3.2.5",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.13",
    "vite-plugin-static-copy": "^3.1.4",
    "vite-plus": "^0.1.13",
    "web-ext": "^9.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "eventemitter3": "^5.0.1",
    "webextension-polyfill": "^0.12.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.13",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.13",
    "playwright": "1.57.0",
    "playwright-core": "1.57.0"
  }
}
