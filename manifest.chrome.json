{
  "manifest_version": 2,
  "name": "Copy URL on Hover Custom",
  "version": "2.0.0",
  "description": "Copy URLs or link text while hovering over links. Enhanced Quick Tabs with navigation, minimize, and sidebar manager.",

  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>",
    "downloads",
    "clipboardWrite",
    "scripting"
  ],

  "commands": {
    "toggle-quick-tabs-manager": {
      "suggested_key": {
        "default": "Alt+Shift+Z"
      },
      "description": "Toggle Quick Tabs Manager panel"
    }
  },

  "browser_action": {
    "default_title": "Copy URL on Hover Settings",
    "default_popup": "popup.html",
    "default_icon": "icons/icon.png"
  },

  "background": {
    "scripts": ["dist/browser-polyfill.min.js", "dist/background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/browser-polyfill.min.js", "dist/content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],

  "web_accessible_resources": [],

  "icons": {
    "48": "icons/icon.png",
    "96": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
